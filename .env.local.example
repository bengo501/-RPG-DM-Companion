# === Supabase ===
# Crie um projeto grátis em https://supabase.com e copie estes valores
# de Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Connection string do Postgres (Project Settings > Database > Connection string > URI)
# Use a porta 6543 (pooler) para a app e 5432 para migrations, conforme o Supabase indicar.
DATABASE_URL=
